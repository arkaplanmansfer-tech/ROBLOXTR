loadstring([[
    -- ============================================
    -- 📋 KATEGORİLER VE İFADELER
    -- ============================================
    
    local CATEGORIES = {
        {
            name = "🎭 Eylemler",
            emotes = {
                {name = "👋 Selam", anim = "wave"},
                {name = "🙋 İşaret", anim = "point"},
                {name = "🤝 Tokalaş", anim = "handshake"},
                {name = "🙏 Dua", anim = "pray"},
                {name = "👑 Selam", anim = "bow"},
                {name = "🤔 Düşün", anim = "think"},
            }
        },
        {
            name = "💃 Dans",
            emotes = {
                {name = "💃 Dans", anim = "dance"},
                {name = "🕺 Dans2", anim = "dance2"},
                {name = "🎸 Gitar", anim = "guitar"},
                {name = "🤳 Selfie", anim = "selfie"},
                {name = "🙌 Havaya", anim = "cheer"},
            }
        },
        {
            name = "🧘 Şekiller",
            emotes = {
                {name = "🧘 Otur", anim = "sit"},
                {name = "🧎 Yere Kapan", anim = "lay"},
                {name = "😴 Uyu", anim = "sleep"},
                {name = "💪 Kas", anim = "muscle"},
                {name = "🤸 Takla", anim = "flip"},
            }
        },
        {
            name = "⚔️ Dövüş",
            emotes = {
                {name = "🥊 Yumruk", anim = "punch"},
                {name = "🦵 Tekme", anim = "kick"},
                {name = "💢 Kızma", anim = "angry"},
                {name = "😭 Ağla", anim = "cry"},
            }
        },
    }
    
    -- ============================================
    -- 🎮 İFADE OYNATMA (GÜNCEL ve ÇALIŞIR)
    -- ============================================
    
    local player = game.Players.LocalPlayer
    local UserInputService = game:GetService("UserInputService")
    
    -- Karakter ve humanoid'i takip et
    local function getHumanoid()
        local char = player.Character
        if not char then return nil end
        return char:FindFirstChild("Humanoid")
    end
    
    local function playEmote(emoteName)
        local humanoid = getHumanoid()
        if not humanoid then
            warn("Humanoid bulunamadı!")
            return
        end
        
        -- Önceki animasyonları durdur
        for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do
            track:Stop()
        end
        
        -- Animasyon ID'leri (ROBLOX'un resmi emote ID'leri)
        local animMap = {
            wave = "507770000",
            point = "507771333",
            handshake = "507771111",
            pray = "507770234",
            bow = "507771222",
            think = "507770666",
            dance = "507770456",
            dance2 = "507770789",
            guitar = "507770888",
            selfie = "507771444",
            cheer = "507770333",
            sit = "507770000",
            lay = "507770222",
            sleep = "507770777",
            muscle = "507770567",
            flip = "507770890",
            punch = "507770999",
            kick = "507771000",
            angry = "507770444",
            cry = "507770555",
        }
        
        local animId = animMap[emoteName]
        if not animId then
            warn("Animasyon bulunamadı: " .. emoteName)
            return
        end
        
        -- Animasyonu yükle ve oynat
        pcall(function()
            local anim = Instance.new("Animation")
            anim.AnimationId = "rbxassetid://" .. animId
            local track = humanoid:LoadAnimation(anim)
            track:Play()
            
            -- 4 saniye sonra durdur
            task.wait(4)
            if track and track.IsPlaying then
                track:Stop()
            end
        end)
    end
    
    -- ============================================
    -- 📱 PANEL ARAYÜZÜ (KAYDIRMA ve SÜRÜKLEME)
    -- ============================================
    
    -- Eski GUI'yi sil
    local oldGui = player.PlayerGui:FindFirstChild("RobloxTR_Gui")
    if oldGui then oldGui:Destroy() end
    
    local sg = Instance.new("ScreenGui")
    sg.Name = "RobloxTR_Gui"
    sg.Parent = player.PlayerGui
    sg.ResetOnSpawn = false
    
    -- ============================================
    -- 🔘 AÇMA BUTONU (SAĞ ÜST)
    -- ============================================
    
    local tog = Instance.new("TextButton")
    tog.Name = "ToggleButton"
    tog.Parent = sg
    tog.BackgroundColor3 = Color3.fromRGB(255, 200, 50)
    tog.BackgroundTransparency = 0
    tog.Position = UDim2.new(1, -55, 0, 10)
    tog.Size = UDim2.new(0, 45, 0, 45)
    tog.Font = Enum.Font.SourceSansBold
    tog.Text = "⚡"
    tog.TextColor3 = Color3.fromRGB(0, 0, 0)
    tog.TextSize = 20
    tog.ZIndex = 10
    tog.AutoButtonColor = true
    
    local togCorner = Instance.new("UICorner")
    togCorner.CornerRadius = UDim.new(1, 0)
    togCorner.Parent = tog
    
    -- ============================================
    -- 📱 ANA PANEL (KÜÇÜK, KAYDIRMALI, YUKARIDA)
    -- ============================================
    
    local mf = Instance.new("Frame")
    mf.Name = "MainFrame"
    mf.Parent = sg
    mf.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    mf.BackgroundTransparency = 0
    mf.Position = UDim2.new(0.05, 0, 0.02, 0)  -- En üste yakın
    mf.Size = UDim2.new(0, 300, 0, 350)
    mf.Visible = true
    mf.ZIndex = 5
    
    local mc = Instance.new("UICorner")
    mc.CornerRadius = UDim.new(0, 12)
    mc.Parent = mf
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(255, 200, 50)
    stroke.Thickness = 2
    stroke.Parent = mf
    
    -- Başlık
    local title = Instance.new("TextLabel")
    title.Parent = mf
    title.BackgroundTransparency = 1
    title.Position = UDim2.new(0, 10, 0, 8)
    title.Size = UDim2.new(0, 200, 0, 25)
    title.Font = Enum.Font.SourceSansBold
    title.Text = "⚡ RobloxTR 1.8.5"
    title.TextColor3 = Color3.fromRGB(255, 200, 50)
    title.TextSize = 14
    title.TextXAlignment = Enum.TextXAlignment.Left
    
    -- Kapatma
    local closeBtn = Instance.new("TextButton")
    closeBtn.Parent = mf
    closeBtn.BackgroundTransparency = 1
    closeBtn.Position = UDim2.new(1, -25, 0, 8)
    closeBtn.Size = UDim2.new(0, 18, 0, 18)
    closeBtn.Font = Enum.Font.SourceSansBold
    closeBtn.Text = "✕"
    closeBtn.TextColor3 = Color3.fromRGB(255, 80, 80)
    closeBtn.TextSize = 14
    closeBtn.MouseButton1Click:Connect(function()
        mf.Visible = false
    end)
    
    -- SCROLL (KAYDIRMA)
    local scroll = Instance.new("ScrollingFrame")
    scroll.Parent = mf
    scroll.Position = UDim2.new(0, 5, 0, 35)
    scroll.Size = UDim2.new(1, -10, 1, -40)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    scroll.ZIndex = 6
    scroll.ScrollBarThickness = 4
    scroll.ScrollBarImageColor3 = Color3.fromRGB(255, 200, 50)
    
    local layout = Instance.new("UIListLayout")
    layout.Parent = scroll
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 5)
    
    -- ============================================
    -- 📋 KATEGORİ OLUŞTUR
    -- ============================================
    
    local function CreateCategory(categoryData)
        -- Kategori başlığı
        local catFrame = Instance.new("Frame")
        catFrame.Parent = scroll
        catFrame.Size = UDim2.new(0, 280, 0, 24)
        catFrame.BackgroundColor3 = Color3.fromRGB(255, 200, 50)
        catFrame.BackgroundTransparency = 0.2
        catFrame.BorderSizePixel = 0
        
        local catCorner = Instance.new("UICorner")
        catCorner.CornerRadius = UDim.new(0, 4)
        catCorner.Parent = catFrame
        
        local catLabel = Instance.new("TextLabel")
        catLabel.Parent = catFrame
        catLabel.BackgroundTransparency = 1
        catLabel.Size = UDim2.new(1, 0, 1, 0)
        catLabel.Font = Enum.Font.SourceSansBold
        catLabel.Text = categoryData.name
        catLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        catLabel.TextSize = 12
        
        -- Butonlar
        local btnFrame = Instance.new("Frame")
        btnFrame.Parent = scroll
        btnFrame.Size = UDim2.new(0, 280, 0, 0)
        btnFrame.BackgroundTransparency = 1
        
        local grid = Instance.new("UIGridLayout")
        grid.Parent = btnFrame
        grid.CellSize = UDim2.new(0, 85, 0, 26)
        grid.CellPadding = UDim2.new(0, 3, 0, 3)
        grid.SortOrder = Enum.SortOrder.LayoutOrder
        
        for _, emote in ipairs(categoryData.emotes) do
            local btn = Instance.new("TextButton")
            btn.Parent = btnFrame
            btn.Size = UDim2.new(0, 85, 0, 26)
            btn.BackgroundColor3 = Color3.fromRGB(50, 50, 65)
            btn.Font = Enum.Font.SourceSansBold
            btn.Text = emote.name
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.TextSize = 10
            btn.AutoButtonColor = true
            btn.ZIndex = 7
            
            local btnCorner = Instance.new("UICorner")
            btnCorner.CornerRadius = UDim.new(0, 4)
            btnCorner.Parent = btn
            
            btn.MouseButton1Click:Connect(function()
                playEmote(emote.anim)
                btn.BackgroundColor3 = Color3.fromRGB(0, 180, 60)
                task.wait(0.1)
                btn.BackgroundColor3 = Color3.fromRGB(50, 50, 65)
            end)
        end
        
        task.wait(0.1)
        btnFrame.Size = UDim2.new(0, 280, 0, grid.AbsoluteContentSize.Y + 4)
    end
    
    -- Kategorileri ekle
    for _, cat in ipairs(CATEGORIES) do
        CreateCategory(cat)
    end
    
    -- Scroll boyutunu güncelle
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 10)
    end)
    
    -- ============================================
    -- 🔘 PANEL AÇ/KAPA
    -- ============================================
    
    tog.MouseButton1Click:Connect(function()
        mf.Visible = not mf.Visible
        print("Panel durumu: " .. tostring(mf.Visible))
    end)
    
    -- ============================================
    -- 🖱️ PANEL ve BUTON SÜRÜKLEME
    -- ============================================
    
    -- Panel sürükleme
    local panelDragging = false
    local panelDragStart, panelStartPos
    
    mf.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            panelDragging = true
            panelDragStart = input.Position
            panelStartPos = mf.Position
        end
    end)
    
    mf.InputEnded:Connect(function()
        panelDragging = false
    end)
    
    mf.InputChanged:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) and panelDragging then
            local delta = input.Position - panelDragStart
            mf.Position = UDim2.new(
                panelStartPos.X.Scale,
                panelStartPos.X.Offset + delta.X,
                panelStartPos.Y.Scale,
                panelStartPos.Y.Offset + delta.Y
            )
        end
    end)
    
    -- Buton sürükleme
    local btnDragging = false
    local btnDragStart, btnStartPos
    
    tog.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            btnDragging = true
            btnDragStart = input.Position
            btnStartPos = tog.Position
        end
    end)
    
    tog.InputEnded:Connect(function()
        btnDragging = false
    end)
    
    tog.InputChanged:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) and btnDragging then
            local delta = input.Position - btnDragStart
            tog.Position = UDim2.new(
                btnStartPos.X.Scale,
                btnStartPos.X.Offset + delta.X,
                btnStartPos.Y.Scale,
                btnStartPos.Y.Offset + delta.Y
            )
        end
    end)
    
    -- ============================================
    -- ⌨️ Z TUŞU
    -- ============================================
    
    UserInputService.InputBegan:Connect(function(input)
        if input.KeyCode == Enum.KeyCode.Z then
            mf.Visible = not mf.Visible
        end
    end)
    
    print("✅ RobloxTR 1.8.5 yüklendi! Tüm tuşlar çalışıyor.")
    print("📱 Sağ üstteki ⚡ butonuna tıkla")
    print("🔄 Panel ve buton sürüklenebilir")
]])()

print("🎮 RobloxTR 1.8.5 başlatıldı!")
