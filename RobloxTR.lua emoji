loadstring([[
    local CATEGORIES = {
        {
            name = "🎭 Eylemler",
            emotes = {
                {name = "👋 Selam", anim = "wave"},
                {name = "🙋 İşaret", anim = "point"},
                {name = "🙌 Havaya", anim = "cheer"},
                {name = "🤔 Düşün", anim = "think"},
            }
        },
        {
            name = "💃 Dans",
            emotes = {
                {name = "💃 Dans", anim = "dance"},
                {name = "🕺 Dans2", anim = "dance2"},
                {name = "🕺 Dans3", anim = "dance3"},
            }
        }
    }
    
    local player = game.Players.LocalPlayer
    local UserInputService = game:GetService("UserInputService")
    
    local function playEmote(emoteName)
        local char = player.Character
        if not char then return end
        local humanoid = char:FindFirstChild("Humanoid")
        if not humanoid then return end
        
        -- Yeni Roblox sistemi: Animator kontrolü
        local animator = humanoid:FindFirstChild("Animator")
        if not animator then
            animator = Instance.new("Animator")
            animator.Parent = humanoid
        end
        
        -- Önceki animasyonları durdur
        for _, track in pairs(animator:GetPlayingAnimationTracks()) do
            track:Stop()
        end
        
        -- GÜNCEL VE ÇALIŞAN VARSAYILAN ROBLOX ID'LERİ
        local animMap = {
            wave = "rbxassetid://507770239",
            point = "rbxassetid://507770453",
            cheer = "rbxassetid://507770677",
            think = "rbxassetid://507771239",
            dance = "rbxassetid://507771019",
            dance2 = "rbxassetid://507771955",
            dance3 = "rbxassetid://507772104"
        }
        
        local animId = animMap[emoteName]
        if not animId then return end
        
        local success, track = pcall(function()
            local anim = Instance.new("Animation")
            anim.AnimationId = animId
            return animator:LoadAnimation(anim)
        end)
        
        if success and track then
            track:Play()
        end
    end

    -- UI ve Diğer Kodlar (Buradan sonrası senin mevcut panel kodunla aynı kalabilir)
    -- ... (Panel oluşturma ve buton tıklama kodlarını buraya ekleyebilirsin)
]])()
