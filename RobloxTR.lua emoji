    -- Roblox'un yerleşik emote sistemini kullan
    local function playEmote(emoteName)
        local char = player.Character
        if not char then return end
        local humanoid = char:FindFirstChild("Humanoid")
        if not humanoid then return end
        
        -- Önceki animasyonları durdur
        for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do
            track:Stop()
        end
        
        -- 1. YÖNTEM: Roblox'un emote sistemi (Animasyonlar)
        local animMap = {
            wave = "rbxassetid://507770000",
            point = "rbxassetid://507771333",
            handshake = "rbxassetid://507771111",
            pray = "rbxassetid://507770234",
            bow = "rbxassetid://507771222",
            think = "rbxassetid://507770666",
            dance = "rbxassetid://507770456",
            dance2 = "rbxassetid://507770789",
            guitar = "rbxassetid://507770888",
            selfie = "rbxassetid://507771444",
            cheer = "rbxassetid://507770333",
            sit = "rbxassetid://507770000",
            lay = "rbxassetid://507770222",
            sleep = "rbxassetid://507770777",
            muscle = "rbxassetid://507770567",
            flip = "rbxassetid://507770890",
            punch = "rbxassetid://507770999",
            kick = "rbxassetid://507771000",
            angry = "rbxassetid://507770444",
            cry = "rbxassetid://507770555",
        }
        
        local animId = animMap[emoteName]
        if not animId then
            warn("Animasyon bulunamadı: " .. emoteName)
            return
        end
        
        -- Animasyonu dene
        local success, track = pcall(function()
            local anim = Instance.new("Animation")
            anim.AnimationId = animId
            return humanoid:LoadAnimation(anim)
        end)
        
        if success and track then
            track:Play()
            task.wait(4)
            if track.IsPlaying then track:Stop() end
        else
            -- 2. YÖNTEM: Alternatif - CharacterAnimator'ı dene
            local animator = char:FindFirstChild("Animator")
            if animator then
                -- Animator üzerinden emote dene
                for _, track in pairs(animator:GetPlayingAnimationTracks()) do
                    if track.Name:lower():find(emoteName:lower()) then
                        track:Play()
                        task.wait(4)
                        track:Stop()
                        return
                    end
                end
            end
            warn("Animasyon oynatılamadı: " .. emoteName)
        end
    end
    
